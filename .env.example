# ---------------------------------------------------------------------------
# WP Autopilot configuration
# Copy this file to ".env" and fill in values. Anything you set here can also
# be set later in the dashboard (Settings tab) — the dashboard values win.
# ---------------------------------------------------------------------------

# Port the local dashboard + API listens on
PORT=4317

# A long random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Optional legacy shared-password gate (leave blank — the login system below supersedes it)
DASHBOARD_PASSWORD=
# The login/register gate is ON by default (first visit → create the super admin).
# Uncomment to run completely open with NO login (single-user / localhost only):
# AUTH_DISABLED=1

# --- Supabase (cloud persistence + multi-tenant) ---------------------------
# These three CREDENTIALS are read ONLY from here (.env) — never stored in the
# dashboard/database, for security. Create a project at https://supabase.com →
# Project Settings → API, copy the values, then run the downloadable schema
# (Settings → Supabase → Download schema SQL) in the SQL editor.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
# Make Supabase the PRIMARY store (hydrate on boot + mirror every change up).
# Turn on ONLY after your first "Back up now" so the cloud has your data. Can
# also be toggled in Settings → Supabase. Blank = local SQLite stays primary
# with Supabase as optional backup.
# SUPABASE_PRIMARY=1

# ===========================================================================
# MULTI-TENANCY: the FIRST user to register becomes the super admin and owns the
# SHARED settings below (AI writers + Ahrefs — used by everyone). WordPress and
# Search Console are PER-TENANT — each registered owner connects their own in
# the dashboard. Values below seed the super admin's account.
# ===========================================================================

# --- WordPress (PER-TENANT: super admin's own site) ------------------------
# Your site URL, no trailing slash, e.g. https://durdurhardware.com
WP_BASE_URL=
# A WordPress username with Editor/Admin rights
WP_USERNAME=
# An Application Password (Users > Profile > Application Passwords). Keep the spaces.
WP_APP_PASSWORD=

# --- Ahrefs API (SHARED across all tenants) --------------------------------
# API token from https://ahrefs.com/api  (v3 / "API key" bearer token)
AHREFS_API_TOKEN=

# --- AI writer (SHARED across all tenants) ---------------------------------
# Provider: anthropic | openai | deepseek
AI_PROVIDER=anthropic
# Model id, e.g. claude-sonnet-4-6 / gpt-5.5 / deepseek-chat / deepseek-reasoner
AI_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# DeepSeek (OpenAI-compatible). Key from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# --- Google Search Console (PER-TENANT: super admin's own property) --------
# Google Cloud Console > enable "Google Search Console API" > OAuth client (Web).
# Authorised redirect URI must be:  http://localhost:4317/api/gsc/callback
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
# Your verified property, e.g. https://yoursite.com/  OR  sc-domain:yoursite.com
GSC_SITE_URL=
# (the refresh token is obtained via the "Connect" button and stored in the DB)
